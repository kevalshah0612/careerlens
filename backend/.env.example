# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobpulse?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"

# OpenAI
OPENAI_API_KEY="sk-your-key-here"

# Server
PORT="3000"
NODE_ENV="development"

# Kafka (optional - can use BullMQ instead)
KAFKA_BROKERS="localhost:9092"
USE_KAFKA="false"

# Job Fetching Config
HOURS_FILTER="24"
ATS_BATCH_SIZE="8"
ATS_DELAY_MS="100"
POLL_INTERVAL_MS="180000"

# Cache TTL (seconds)
CACHE_JOBS_TTL="300"
CACHE_SEARCH_TTL="300"
